# Postgres connection string (Vercel Postgres / Neon in prod, local Podman in dev).
# Local dev example: postgresql://postgres:<password>@localhost:5433/gungeon
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-32-char-secret

# The deployed origin. Passkey Relying Party ID is derived from this hostname,
# so it MUST match the domain you actually visit.
BETTER_AUTH_URL=http://localhost:3000

# Public base URL used by the browser client (same origin as BETTER_AUTH_URL).
NEXT_PUBLIC_APP_URL=http://localhost:3000
